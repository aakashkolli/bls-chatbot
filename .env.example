# UIUC.chat API Configuration
# Copy this file to .env and fill in your actual keys

# Your UIUC.chat API key (generate from Materials page at https://uiuc.chat)
# Steps:
# 1. Go to https://uiuc.chat
# 2. Navigate to your project
# 3. Go to Materials page
# 4. Click "Generate API Key"
# 5. Copy and paste below
UIUC_CHAT_API_KEY=YOUR_API_KEY_HERE

# Your UIUC.chat course/project name
COURSE_NAME=YOUR_CHATBOT_NAME_HERE

# Model selection - Free NCSA-hosted model (no cost!)
# Options: Qwen/Qwen2.5-VL-72B-Instruct (free), llama3.1:70b (free)
MODEL=Qwen/Qwen2.5-VL-72B-Instruct

# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=True
